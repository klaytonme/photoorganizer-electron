{
	"name": "photo-organizer",
	"version": "1.0.0",
	"description": "A keyboard-driven photo sorting app",
	"main": "main.js",
	"scripts": {
		"dev": "concurrently \"cd renderer && npm run dev\" \"wait-on http://localhost:3000 && NODE_ENV=development electron .\"",
		"build": "cd renderer && npm run build",
		"start": "electron ."
	},
	"dependencies": {
		"next": "^14.0.0",
		"react": "^18.0.0",
		"react-dom": "^18.0.0",
		"sharp": "^0.33.0"
	},
	"devDependencies": {
		"autoprefixer": "^10.0.0",
		"concurrently": "^8.0.0",
		"electron": "^28.0.0",
		"electron-builder": "^24.0.0",
		"postcss": "^8.0.0",
		"tailwindcss": "^3.0.0",
		"wait-on": "^7.0.0"
	},
	"build": {
		"appId": "com.photoorganizer.app",
		"mac": {
			"category": "public.app-category.photography"
		},
		"files": [
			"main.js",
			"preload.js",
			"renderer/.next/**",
			"renderer/public/**"
		]
	}
}